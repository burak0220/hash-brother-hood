# ============================================================
# HashBrotherHood — Production Environment Variables
# Copy to .env and fill in real values before deploying.
# NEVER commit the filled-in .env file to version control!
# ============================================================

# ── Environment ─────────────────────────────────────────────
ENV=production

# ── Database ────────────────────────────────────────────────
DB_PASSWORD=CHANGE_ME_strong_db_password_here
# DATABASE_URL is auto-constructed from DB_PASSWORD in docker-compose

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_strong_redis_password_here

# ── Security ────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_64_char_hex_secret_key_here

JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=1
JWT_REFRESH_EXPIRY_DAYS=7

# Internal API key shared between API and stratum proxy
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_KEY=CHANGE_ME_internal_api_key_here

# ── Admin account ────────────────────────────────────────────
# Default admin password (changed on first login recommended)
# If left blank, defaults to Admin123! — CHANGE THIS
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_admin_password_here

# ── Litecoin (mainnet) ───────────────────────────────────────
LTC_NETWORK=mainnet

# Optional: Run your own Litecoin node for better reliability
# Leave blank to use BlockCypher API (requires BLOCKCYPHER_TOKEN)
LTC_RPC_URL=
LTC_RPC_USER=
LTC_RPC_PASSWORD=

# Hot wallet — platform wallet that receives sweeps and sends withdrawals
# Get a Litecoin address from any wallet (Electrum-LTC, etc.)
HOT_WALLET_ADDRESS=ltc1_YOUR_HOT_WALLET_ADDRESS_HERE

# WIF (Wallet Import Format) private key for the hot wallet above
# CRITICAL: Keep this secret. Used to sign withdrawal transactions.
HOT_WALLET_PRIVATE_KEY=T_YOUR_WIF_PRIVATE_KEY_HERE

# BIP39 mnemonic (12-24 words) used to derive unique deposit addresses
# Generate at: https://iancoleman.io/bip39/ — use a HARDWARE wallet for production!
# CRITICAL: Back this up. Losing it = losing all user deposits.
HD_WALLET_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# BlockCypher API token — free at https://accounts.blockcypher.com/
# Required for deposit scanning. Without token: 200 req/hour (may not be enough)
BLOCKCYPHER_TOKEN=CHANGE_ME_blockcypher_token_here

# ── Frontend ────────────────────────────────────────────────
# Replace yourdomain.com with your actual domain
NEXT_PUBLIC_API_URL=https://yourdomain.com/api
NEXT_PUBLIC_WS_URL=wss://yourdomain.com
# Stratum proxy address — miners will connect here
NEXT_PUBLIC_STRATUM_HOST=stratum.yourdomain.com
NEXT_PUBLIC_STRATUM_PORT=3333

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com

# ── Stratum proxy ────────────────────────────────────────────
# How often (seconds) the proxy reports hashrate to the API
HASHRATE_REPORT_INTERVAL=300
# How long (seconds) to cache pool config per rig
POOL_LOOKUP_CACHE_SEC=60

# ── Email (optional) ─────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=

# ── Monitoring (optional) ────────────────────────────────────
SENTRY_DSN=
