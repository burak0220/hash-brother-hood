# Database
DB_PASSWORD=your_secure_password
DATABASE_URL=postgresql+asyncpg://hashrent:your_secure_password@localhost:5432/hashrent

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-256-bit-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# BSC Network (Binance Smart Chain - USDT BEP-20)
# RPC endpoint for BSC mainnet
BSC_RPC_URL=https://bsc-dataseed.binance.org/
# Hot wallet address - platform wallet that receives deposits and sends withdrawals
HOT_WALLET_ADDRESS=0xYourBSCWalletAddressHere
# Hot wallet private key - KEEP SECRET! Required to auto-send USDT withdrawals
HOT_WALLET_PRIVATE_KEY=your_private_key_here

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Email (optional)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=

# Monitoring
SENTRY_DSN=
