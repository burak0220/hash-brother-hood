# Database
DB_PASSWORD=your_secure_password
DATABASE_URL=postgresql+asyncpg://hashrent:your_secure_password@localhost:5432/hashrent

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=your-256-bit-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# Litecoin Network
LTC_NETWORK=mainnet
# Optional: Litecoin node JSON-RPC (leave empty to use bitcoinlib built-in)
LTC_RPC_URL=
LTC_RPC_USER=
LTC_RPC_PASSWORD=
# Hot wallet address - platform wallet for withdrawals (ltc1... or L... format)
HOT_WALLET_ADDRESS=LYourLitecoinAddressHere
# Hot wallet private key - KEEP SECRET! Required to auto-send LTC withdrawals (WIF format)
HOT_WALLET_PRIVATE_KEY=your_wif_private_key_here
# HD Wallet Mnemonic - KEEP SECRET! Used to generate unique deposit addresses for each user
# Generate with any BIP39 mnemonic generator (e.g. https://iancoleman.io/bip39/ or a hardware wallet)
# Must be 12, 15, 18, 21, or 24 words. Example: "word1 word2 ... word12"
HD_WALLET_MNEMONIC=your twelve word mnemonic phrase here

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Email (optional)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=

# Monitoring
SENTRY_DSN=

# BlockCypher API token (optional but recommended — increases rate limit significantly)
# Free registration at: https://accounts.blockcypher.com/
BLOCKCYPHER_TOKEN=

# Internal Services
INTERNAL_API_KEY=internal-secret-key-change-in-production-xyz789
